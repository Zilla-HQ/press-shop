# Press — example environment variables.
#
# Copy to platform/web/.env.local for local dev.
# For Vercel: paste each value into Project Settings → Environment
# Variables. Mark all as available to Production + Preview + Development.
#
# Press shares Shopify, Printful, and Neon with Anchor (the curated
# cap brand at anchorhats.com). Set the same values in both Vercel
# projects.

# --- Shopify Admin API (Bolthouse operator store) ------------
SHOPIFY_SHOP_DOMAIN=                   # bolthouse-vzgkujpc.myshopify.com
SHOPIFY_DEVAPP_CLIENT_ID=              # Zilla Operator Partner app
SHOPIFY_DEVAPP_CLIENT_SECRET=          # Zilla Operator Partner app

# --- Printful (shared fulfillment) ---------------------------
PRINTFUL_API_KEY=                      # private token
PRINTFUL_STORE_ID=                     # 18166792 (bolthouse-connected)
# PRINTFUL_AUTO_CONFIRM=1              # auto-confirm orders for production

# --- Vercel Blob (optional, only if you persist designs locally) ---
# BLOB_READ_WRITE_TOKEN=

# --- Neon Postgres (shared brand_orders table) ---------------
DATABASE_URL=

# --- Resend (email) ------------------------------------------
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# --- Optional ------------------------------------------------
# NEXT_PUBLIC_APP_URL=                 # override the canonical app URL
